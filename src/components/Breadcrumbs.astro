---
export interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav aria-label="Ruta de navegación">
  <ol class="breadcrumbs">
    <li><a href="/">Inicio</a></li>
    {items.map((item) => (
      <li>
        {item.href ? <a href={item.href}>{item.label}</a> : <span aria-current="page">{item.label}</span>}
      </li>
    ))}
  </ol>
</nav>
