# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Public base URL of the Cloudflare R2 bucket (or a custom domain fronting
# it) that serves original photos. Used at build time so Astro's <Image />
# component is allowed to fetch + optimize those remote originals.
# Example: https://pub-xxxxxxxxxxxx.r2.dev  (R2.dev public bucket URL)
# or:      https://media.your-domain.com     (custom domain via Cloudflare)
PUBLIC_R2_BASE_URL=

# Public canonical site URL, used to generate absolute URLs in sitemap.xml
# and Open Graph tags. Use the *.pages.dev URL until a custom domain exists.
PUBLIC_SITE_URL=https://photopage.pages.dev

# --- Credentials for uploading/managing photos in R2 (used by upload
# tooling such as `rclone`/`aws s3` on your machine or in CI, NOT by the
# Astro build itself). Generate these in the Cloudflare dashboard under
# R2 > Manage R2 API Tokens. See README.md "Configuración de R2" section.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
